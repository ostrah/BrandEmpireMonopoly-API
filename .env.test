# Environment overrides for the test runner.
# Loaded by vitest.config.ts BEFORE any src/ module imports env.ts.
NODE_ENV=test
PORT=4001

# Isolated test database on the same Postgres instance.
DATABASE_URL=postgresql://beuser:bepass@localhost:5432/brand_empire_test

# Short TTLs make expiry tests feasible. Override per test when needed.
JWT_ACCESS_SECRET=test_access_secret_000000000000000000000000000000000000000000000000
JWT_REFRESH_SECRET=test_refresh_secret_00000000000000000000000000000000000000000000000
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# SMTP credentials are irrelevant — nodemailer is mocked in tests/setup.ts.
SMTP_HOST=smtp.example.test
SMTP_PORT=587
SMTP_USER=tests@example.test
SMTP_PASS=ignored
SMTP_FROM="Test <tests@example.test>"

FRONTEND_URL=http://localhost:5173
API_BASE_URL=http://localhost:4001

# Explicitly disable Redis in tests — WS runs in single-instance mode.
# dotenv does not overwrite existing process.env entries, so this prevents
# the dev .env from leaking REDIS_URL into the test worker.
REDIS_URL=

