# Server
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://beuser:bepass@localhost:5432/brand_empire

# Redis (для следующего этапа, но пусть будет)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=change_this_to_random_64_chars_string_abc123xyz789
JWT_REFRESH_SECRET=change_this_to_another_random_64_chars_string_qwe456rty
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d

# Gmail SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
SMTP_FROM="Brand Empire Monopoly <your_email@gmail.com>"

# Frontend URL (target for post-auth redirects, app landing, etc.)
FRONTEND_URL=http://localhost:5173

# Public base URL of THIS API — used as the click-target in email links.
# In production set this to https://api.yourdomain.com.
API_BASE_URL=http://localhost:4000
